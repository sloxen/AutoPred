irrigation <- read_csv("data/irrigation.csv")
View(irrigation)
ggplot(irrigation, aes(x = irrigation, y = yield, colour = variety)) +
geom_point()
ggplot(irrigation, aes(x = irrigation, y = yield, colour = field)) +
geom_point()
summary(lme_yield)
lme_yield <- lmer(yield ~ irrigation*variety + (1|field), data = irrigation)
summary(lme_yield)
View(lme_yield)
augment(lme_yield)
ggplot(augment(lme_yield), aes(x = irrigation, y = yield, colour = variety)) +
geom_point(aes(shape = "observed"), size = 3) +
geom_point(aes(y = .fitted, shape = "predicted"), size = 3)
solutions <- read_csv("data/solutions.csv")
View(solutions)
solutions <- read_csv("data/solutions.csv")
solutions_avg <- solutions %>%
group_by(solvent,solute) %>%
mutate(dissolve_avg=mean(dissolve)) %>%
ungroup() %>%
select(solvent,solute,dissolve_avg) %>%
distinct()
View(solutions_avg)
ggplot(solutions_avg, aes(x = water, y = dissolve_avg, colour = solute)) +
geom_point()
solutions <- read_csv("data/solutions.csv")
solutions_avg <- solutions %>%
group_by(solvent,solute) %>%
mutate(dissolve_avg=mean(dissolve)) %>%
ungroup() %>%
select(solvent,solute,dissolve_avg) %>%
distinct()
ggplot(solutions_avg, aes(x = water, y = dissolve_avg, colour = solute)) +
geom_point()
solutions <- read_csv("data/solutions.csv")
solutions_avg <- solutions %>%
group_by(solvent,solute) %>%
mutate(dissolve_avg=mean(dissolve)) %>%
ungroup() %>%
select(solvent,solute,dissolve_avg) %>%
distinct()
ggplot(solutions_avg, aes(x = solvent, y = dissolve_avg, colour = solute)) +
geom_point()
ggplot(solutions_avg, aes(x = solvent, y = dissolve_avg, colour = solute)) +
geom_point()
ggplot(solutions_avg, aes(x = solute, y = dissolve_avg, colour = solvent)) +
geom_point()
lme_dissolve_avg <- lmer(dissolve_avg ~ solvent*solute + (1|solute), data = solutions_avg)
lme_yield <- lmer(yield ~ irrigation*variety + (1|field), data = irrigation)
lme_dissolve_avg <- lmer(dissolve_avg ~ solvent*solute + (1|solute), data = solutions_avg)
lme_dissolve_avg <- lmer(dissolve_avg ~ solvent + (1|solute), data = solutions_avg)
summary(lme_dissolve_avg)
augment(dissolve_avg)
augment(lmer_dissolve_avg)
augment(lme_dissolve_avg)
ggplot(augment(lme_dissolve_avg), aes(x = solute, y = dissolve_avg, colour = solvent)) +
geom_point(aes(shape = "observed"), size = 3) +
geom_point(aes(y = .fitted, shape = "predicted"), size = 3)
lme_dissolve_avg <- lmer(dissolve_avg ~ solute + (1|solvent), data = solutions_avg)
summary(lme_dissolve_avg)
ggplot(augment(lme_dissolve_avg), aes(x = solvent, y = dissolve_avg, colour = solute)) +
geom_point(aes(shape = "observed"), size = 3) +
geom_point(aes(y = .fitted, shape = "predicted"), size = 3)
dragons <- read_csv("data/dragons.csv")
View(dragons)
ggplot(dragons, aes(x = wingspan, y = intelligence, colour = scales)) +
geom_point()
ggplot(dragons, aes(x = wingspan, y = intelligence, colour = scales)) +
facet_wrap(vars(mountain)) +
geom_point()
ggplot(dragons, aes(x = wingspan, y = intelligence, colour = scales)) +
facet_wrap(vars(mountain)) +
geom_point()
lme_dragons <- lmer(intelligence ~ wingspan*scales + (1 + wingspan|mountain),
data=dragons)
summary(lme_dragons)
ggplot(augment(lme_dragons), aes(x = wingspan, y = intelligence, colour = scales)) +
facet_wrap(vars(mountain)) +
geom_point() +
geom_line(aes(y = .fitted))
ggplot(augment(lme_dragons), aes(x = wingspan, y = intelligence, colour = mountain)) +
geom_point() +
# plot the mixed model predictions
geom_line(aes(y = .fitted, linetype = scales)) +
# add the global average regression line
geom_smooth(method = "lm", se = FALSE, colour = "black")
lme_dragons <- lmer(intelligence ~ wingspan*scales + (1 + wingspan*scales|mountain),
data=dragons)
summary(lme_dragons)
ggplot(augment(lme_dragons), aes(x = wingspan, y = intelligence, colour = scales)) +
facet_wrap(vars(mountain)) +
geom_point() +
geom_line(aes(y = .fitted))
ggplot(augment(lme_dragons), aes(x = wingspan, y = intelligence, colour = mountain)) +
geom_point() +
# plot the mixed model predictions
geom_line(aes(y = .fitted, linetype = scales)) +
# add the global average regression line
geom_smooth(method = "lm", se = FALSE, colour = "black")
